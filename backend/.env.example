# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3031

# ─── Database (MySQL) ──────────────────────────────────────────────────────────
# Docker MySQL is mapped to host port 3309 (docker-compose: 3309:3306)
DATABASE_URL="mysql://tfuser:tfpassword@localhost:3309/todaysfamily"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=todaysfamily-images

# ─── OpenAI (AI Caption) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Firebase (Push Notifications) ────────────────────────────────────────────
# Paste the JSON of your Firebase service account as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:8081,https://yourapp.com
